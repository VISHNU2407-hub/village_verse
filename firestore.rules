rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────────────────
    //  HELPER FUNCTIONS
    // ──────────────────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // ──────────────────────────────────────────────────────────────────────────
    //  DEFAULT — deny all unmatched paths
    // ──────────────────────────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }

    // ──────────────────────────────────────────────────────────────────────────
    //  USERS
    //  - Authenticated users may read any user document (needed for donor
    //    search, admin lookup, phone lookup, notification targeting).
    //  - Users may write only their own document.
    //  - Role may be "citizen" or "admin" at creation time.
    //  - Role field is immutable after creation — no changes allowed.
    // ──────────────────────────────────────────────────────────────────────────

    match /users/{userId} {

      // Create: only self, role must be "citizen" or "admin"
      // Role is immutable after creation — enforced by the update rule below.
      allow create: if isAuthenticated()
                    && isOwner(userId)
                    && (request.resource.data.role == "citizen"
                        || request.resource.data.role == "admin");

      // Read: authenticated users may read any profile (donor search,
      // admin lookup, guardian phone lookup, notification targeting).
      allow read: if isAuthenticated();

      // Update: only self, prevent role escalation
      allow update: if isAuthenticated()
                    && isOwner(userId)
                    && (!request.resource.data.keys().hasAny(["role"])
                        || request.resource.data.role == resource.data.role);

      // Delete: not implemented in app
      allow delete: if false;

      // ── Guardians subcollection ──
      match /guardians/{guardianId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ──────────────────────────────────────────────────────────────────────────
    //  COMPLAINTS
    //  - Any authenticated user may create a complaint.
    //  - The complaint creator may read their own complaint.
    //  - Admins may read complaints across the collection.
    //  - The creator may update (add messages) their own complaint.
    //  - Only admins may update complaint status.
    //  - The creator may delete their own complaint.
    // ──────────────────────────────────────────────────────────────────────────

    match /complaints/{complaintId} {

      allow create: if isAuthenticated();

      allow read: if isAuthenticated()
                   && (resource.data.userId == request.auth.uid
                       || isAdmin());

      allow update: if isAuthenticated()
                     && (resource.data.userId == request.auth.uid
                         || isAdmin());

      allow delete: if isAuthenticated()
                     && resource.data.userId == request.auth.uid;

      // ── Complaint messages subcollection ──
      match /messages/{messageId} {
        allow read: if isAuthenticated()
                     && (get(/databases/$(database)/documents/complaints/$(complaintId)).data.userId == request.auth.uid
                         || isAdmin());
        allow create: if isAuthenticated();
        allow delete: if get(/databases/$(database)/documents/complaints/$(complaintId)).data.userId == request.auth.uid;
        allow update: if false;
      }
    }

    // ──────────────────────────────────────────────────────────────────────────
    //  COMMUNITY POSTS
    //  - Any authenticated user may create posts.
    //  - Any authenticated user may read posts.
    //  - Only the original creator may update or delete their own post.
    // ──────────────────────────────────────────────────────────────────────────

    match /posts/{postId} {

      allow create: if isAuthenticated();

      allow read: if isAuthenticated();

      // Owner can edit anything. Non-owner may only update reaction
      // counter fields (like, dislike, heart) that toggleReaction()
      // touches inside a Firestore transaction.
      allow update: if isAuthenticated()
                     && (resource.data.userId == request.auth.uid
                         || request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(["likeCount", "dislikeCount", "heartCount"]));

      allow delete: if isAuthenticated()
                     && resource.data.userId == request.auth.uid;

      // ── Post reactions subcollection ──
      // Document ID equals the reacting user's UID.
      match /reactions/{userId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ──────────────────────────────────────────────────────────────────────────
    //  PINNED POSTS
    //  - Users may only pin/unpin on their own pinned_posts subcollection.
    // ──────────────────────────────────────────────────────────────────────────

    match /pinned_posts/{userId}/posts/{pinId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // ──────────────────────────────────────────────────────────────────────────
    //  NOTIFICATIONS
    //  - Notifications are created server-side via Cloud Functions or
    //    batch writes (the client SDK does not call create directly
    //    from user-facing code in a user-triggered way).
    //  - Users may only read/update/delete notifications where
    //    targetUserId matches their own UID.
    //  - Mark-all-read and delete-all operations use server-side
    //    filtering via `.where('targetUserId', ==, userId)`.
    // ──────────────────────────────────────────────────────────────────────────

    match /notifications/{notificationId} {

      // Notifications are created by server code (batch writes from
      // SOS, complaints, community posts, missing person alerts).
      // The app writes directly from client code for simplicity.
      // Allow create from authenticated users since write logic
      // is in the app's service layer.
      allow create: if isAuthenticated();

      allow read: if isAuthenticated()
                   && resource.data.targetUserId == request.auth.uid;

      allow update: if isAuthenticated()
                     && resource.data.targetUserId == request.auth.uid;

      allow delete: if isAuthenticated()
                     && resource.data.targetUserId == request.auth.uid;
    }

    // ──────────────────────────────────────────────────────────────────────────
    //  EMERGENCIES (SOS)
    //  - Only the SOS initiator may read/update their own emergency.
    //  - Any authenticated user may create an emergency (SOS).
    //  - Delete is not supported.
    // ──────────────────────────────────────────────────────────────────────────

    match /emergencies/{emergencyId} {

      allow create: if isAuthenticated()
                     && request.resource.data.userId == request.auth.uid;

      allow read: if isAuthenticated()
                   && resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated()
                     && resource.data.userId == request.auth.uid;

      allow delete: if false;
    }

    // ──────────────────────────────────────────────────────────────────────────
    //  MISSING PERSON ALERTS
    //  - Any authenticated user may create alerts.
    //  - Any authenticated user may read alerts (public safety).
    //  - The original creator may update or delete their own alert.
    //  - Any user may mark an alert as "found safe" (status change).
    // ──────────────────────────────────────────────────────────────────────────

    match /missing_person_alerts/{alertId} {

      allow create: if isAuthenticated();

      allow read: if isAuthenticated();

      // Creator can do any update; any authenticated user can mark
      // found safe (status, foundAt, updatedAt fields only).
      allow update: if isAuthenticated()
                     && (resource.data.createdBy == request.auth.uid
                         || request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(["status", "foundAt", "updatedAt"]));

      allow delete: if isAuthenticated()
                     && resource.data.createdBy == request.auth.uid;
    }

    // ──────────────────────────────────────────────────────────────────────────
    //  HOSPITALS
    //  - Seeded via standalone scripts. Read-only from client code.
    // ──────────────────────────────────────────────────────────────────────────

    match /hospitals/{hospitalId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
